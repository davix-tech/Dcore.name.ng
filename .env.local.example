# =========================================================
# DCORE — Adaptive Intelligence Infrastructure
# Runtime Environment Configuration
# =========================================================

# ---------------------------------------------------------
# Core Platform
# ---------------------------------------------------------

NODE_ENV=development

NEXT_PUBLIC_APP_NAME=DCORE
NEXT_PUBLIC_APP_URL=http://localhost:3000

NEXT_PUBLIC_RUNTIME_ENV=development
NEXT_PUBLIC_PLATFORM_REGION=global-edge

# ---------------------------------------------------------
# API Infrastructure
# ---------------------------------------------------------

NEXT_PUBLIC_API_URL=http://localhost:3000/api

API_INTERNAL_URL=http://localhost:3000/api/internal

API_TIMEOUT_MS=15000
API_RETRY_ATTEMPTS=3

# ---------------------------------------------------------
# Authentication Runtime
# ---------------------------------------------------------

NEXT_PUBLIC_AUTH_ENABLED=true

AUTH_SECRET=
AUTH_SESSION_EXPIRY=604800

NEXT_PUBLIC_AUTH_PROVIDER=internal-runtime

# ---------------------------------------------------------
# Runtime Security
# ---------------------------------------------------------

SECURITY_RUNTIME_MODE=adaptive

ENABLE_RATE_LIMITING=true
ENABLE_RUNTIME_MONITORING=true
ENABLE_AUDIT_LOGGING=true

# ---------------------------------------------------------
# REDEN Infrastructure
# ---------------------------------------------------------

NEXT_PUBLIC_REDEN_ENABLED=true

REDEN_RUNTIME_MODE=adaptive
REDEN_EXPERIMENTATION_ENABLED=true
REDEN_ANALYTICS_ENABLED=true

# ---------------------------------------------------------
# Infrastructure Systems
# ---------------------------------------------------------

NEXT_PUBLIC_ORBIT_STATUS=experimental
NEXT_PUBLIC_VEKTOR_STATUS=internal
NEXT_PUBLIC_AXIOM_STATUS=development
NEXT_PUBLIC_SYNAPSE_STATUS=future

# ---------------------------------------------------------
# Dashboard Runtime
# ---------------------------------------------------------

NEXT_PUBLIC_DASHBOARD_ENABLED=true

ENABLE_SYSTEM_METRICS=true
ENABLE_DEPLOYMENT_FEED=true
ENABLE_RUNTIME_ACTIVITY=true

# ---------------------------------------------------------
# Analytics + Observability
# ---------------------------------------------------------

NEXT_PUBLIC_ANALYTICS_ENABLED=true

ANALYTICS_PROVIDER=internal-runtime
ENABLE_RUNTIME_TELEMETRY=true
ENABLE_PERFORMANCE_TRACKING=true

# ---------------------------------------------------------
# Experimental Runtime Flags
# ---------------------------------------------------------

ENABLE_AI_ORCHESTRATION=false
ENABLE_BEHAVIORAL_OPTIMIZATION=false
ENABLE_AUTONOMOUS_SCALING=false

# ---------------------------------------------------------
# Operational Modes
# ---------------------------------------------------------

NEXT_PUBLIC_MAINTENANCE_MODE=false

RUNTIME_DEBUG_MODE=false
RUNTIME_VERBOSE_LOGGING=false

# ---------------------------------------------------------
# Deployment Infrastructure
# ---------------------------------------------------------

DEPLOYMENT_TARGET=edge-runtime

ENABLE_CDN_ROUTING=true
ENABLE_GLOBAL_CACHE=true

# ---------------------------------------------------------
# SDK + API Access
# ---------------------------------------------------------

NEXT_PUBLIC_SDK_ACCESS=true
NEXT_PUBLIC_API_ACCESS=true

# ---------------------------------------------------------
# Future Integrations
# ---------------------------------------------------------

OPENAI_API_KEY=
STRIPE_SECRET_KEY=
RESEND_API_KEY=

# ---------------------------------------------------------
# Notes
# ---------------------------------------------------------

# Copy this file to:
# .env.local
#
# Then insert your real infrastructure keys.
